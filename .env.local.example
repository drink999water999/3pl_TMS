# ----------------------------------------------------------------------------
# FastLane TMS — environment variables
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored and never committed.
# ----------------------------------------------------------------------------

# --- Supabase (LOCAL stack) ---------------------------------------------------
# Run `supabase start` (or `supabase status`) and map the printed keys EXACTLY
# as below. Newer CLIs label them "Publishable" / "Secret"; older ones label
# them "anon key" / "service_role key" — they mean the same thing:
#
#   API URL .................. NEXT_PUBLIC_SUPABASE_URL   (usually the one below)
#   Publishable / anon key ... NEXT_PUBLIC_SUPABASE_ANON_KEY   (public, browser-safe)
#   Secret / service_role .... SUPABASE_SERVICE_ROLE_KEY       (SERVER ONLY — never NEXT_PUBLIC)
#
# ⚠️  Do NOT swap these. The Secret/service_role key must NOT go in a
#     NEXT_PUBLIC_ variable, or it would be exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="FastLane Logistics"
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- First admin (used by `pnpm seed:admin`; optional overrides) ---------------
# If omitted, defaults to admin@fastlane.local / ChangeMe123!.
ADMIN_EMAIL=admin@fastlane.local
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME="FastLane Admin"

# --- Resend (Phase 6 — waybill email) -----------------------------------------
# Optional. Without a key, the waybill "Email" button explains it's not set up;
# approve/download/print all work regardless.
# To enable: create a key at https://resend.com/api-keys and paste it below.
# For quick local testing you can send FROM "onboarding@resend.dev" to the email
# you signed up with — no domain verification needed. For real sending, verify
# your own domain and use an address on it.
RESEND_API_KEY=
RESEND_FROM_EMAIL="FastLane Logistics <onboarding@resend.dev>"
